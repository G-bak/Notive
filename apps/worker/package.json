{
  "name": "@notive/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=../../.env src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file-if-exists=../../.env dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@notive/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  }
}
