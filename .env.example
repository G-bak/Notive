# Notive Phase B environment variables
# See docs/operations/notive-deployment-operations-guide-v1.0.md §4.2

# --- Runtime / app general
NODE_ENV=development
APP_BASE_URL=http://localhost:3000
LOG_LEVEL=info

# --- Database
DATABASE_URL=postgresql://notive:notive@localhost:5432/notive
DIRECT_DATABASE_URL=postgresql://notive:notive@localhost:5432/notive

# --- Short-term store
REDIS_URL=redis://localhost:6379

# --- Auth / session
SESSION_SECRET=change-me-32-bytes-or-more-please-do-not-ship-this-default
SESSION_IDLE_TTL_DAYS=14
SESSION_ABSOLUTE_TTL_DAYS=30
PASSWORD_RESET_TTL_MINUTES=60

# --- Mail
MAIL_PROVIDER_API_KEY=replace-me
MAIL_FROM_ADDRESS=no-reply@notive.local
MAIL_VERIFY_TTL_HOURS=24
MAIL_INVITE_TTL_DAYS=7

# --- Worker
WORKER_DESTRUCTIVE_OPS=false
WORKER_RUN_INTERVAL_OVERRIDE=

# --- Reserved (later phases; do not collide)
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=
# STORAGE_BUCKET=
# AI_API_KEY=
# AI_API_BASE_URL=
