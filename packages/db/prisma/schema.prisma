// Notive Phase B database schema.
//
// Single source: docs/database/notive-database-design-v1.0.md §5–§12.
// This Prisma schema is derived from that document. If the two diverge,
// update the doc first, then this file.
//
// Constraints that Prisma cannot express in this schema are added as
// raw SQL migrations. See prisma/migrations/* — specifically:
//   - active_membership_unique: partial unique on memberships(user_id)
//     WHERE status='Active' AND deleted_at IS NULL
//   - last_admin_protection: trigger on memberships UPDATE/DELETE that
//     blocks demoting/disabling/removing the last active Admin.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// ---------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------

enum UserStatus {
  Active
  Pending
  Disabled
  Deleted
}

enum OrganizationStatus {
  Active
  Suspended
  Deleted
}

enum TeamStatus {
  Active
  Archived
  Deleted
}

enum MembershipStatus {
  Active
  Invited
  Disabled
  Removed
}

enum InvitationStatus {
  Pending
  Accepted
  Expired
  Revoked
}

/// System role codes. Phase A §15 / Phase B §9.
enum RoleCode {
  Viewer
  Editor
  Manager
  Admin
}

enum ActivityResult {
  Success
  Failed
}

// ---------------------------------------------------------------------
// Document enums (Phase C / DB design §7)
// ---------------------------------------------------------------------

enum DocumentStatus {
  Draft
  Active
  Archived
  Deleted
}

/// Document share scope. Phase A §15 consolidates Department into Team —
/// no Department value exists or will be added in MVP.
enum DocumentVisibility {
  Private
  Team
  Organization
  SpecificUsers
}

enum DocumentSourceType {
  Manual
  AI
  Imported
}

enum DocumentShareTargetType {
  User
  Team
  Organization
}

enum DocumentSharePermission {
  View
  Edit
  Manage
}

// Phase D step 1: AI request / result / reference / usage-log enums.
// Source: docs/database/notive-database-design-v1.0.md §9 and
// docs/implementation/notive-implementation-plan-d-ai-document-generation-v1.0.md §7.
enum AiRequestStatus {
  Pending
  Processing
  Completed
  Failed
  Cancelled
}

enum AiResultStatus {
  Generated
  Selected
  Saved
  Discarded
  Failed
}

enum AiReferenceTargetType {
  Document
  Template
  DiaryEntry
  Todo
}

enum AiUsageStatus {
  Success
  Failed
  Cancelled
}

// ---------------------------------------------------------------------
// Auth / user tables (DB design §5)
// ---------------------------------------------------------------------

model User {
  id                         String     @id @default(uuid()) @db.Uuid
  name                       String
  email                      String     @unique
  passwordHash               String     @map("password_hash")
  profileImageUrl            String?    @map("profile_image_url")
  status                     UserStatus @default(Pending)
  emailVerifiedAt            DateTime?  @map("email_verified_at")
  lastLoginAt                DateTime?  @map("last_login_at")
  // Phase B step 4: single outstanding token per type per user.
  // Storing only the sha256 hash; raw tokens never persisted.
  // Resend / re-request overwrites the previous row.
  emailVerificationTokenHash String?    @unique @map("email_verification_token_hash")
  emailVerificationExpiresAt DateTime?  @map("email_verification_expires_at")
  passwordResetTokenHash     String?    @unique @map("password_reset_token_hash")
  passwordResetExpiresAt     DateTime?  @map("password_reset_expires_at")
  createdAt                  DateTime   @default(now()) @map("created_at")
  updatedAt                  DateTime   @updatedAt @map("updated_at")
  deletedAt                  DateTime?  @map("deleted_at")

  sessions        Session[]
  memberships     Membership[]
  sentInvitations Invitation[]   @relation("InvitedBy")
  createdOrgs     Organization[] @relation("OrgCreatedBy")
  managedTeams    Team[]         @relation("TeamManager")
  activityLogs    ActivityLog[]  @relation("ActivityActor")

  ownedDocuments        Document[]            @relation("DocumentOwner")
  authoredDocuments     Document[]            @relation("DocumentAuthor")
  documentVersionEdits  DocumentVersion[]     @relation("DocumentVersionChangedBy")
  documentSharesCreated DocumentShare[]       @relation("DocumentShareCreatedBy")
  documentTagsCreated   DocumentTag[]         @relation("DocumentTagCreatedBy")
  documentFavorites     DocumentFavorite[]
  documentViewHistories DocumentViewHistory[]

  aiRequestsRequested AiRequest[]  @relation("AiRequestRequestedBy")
  aiUsageLogs         AiUsageLog[]

  @@index([status])
  @@map("users")
}

model Session {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Invitation {
  id              String           @id @default(uuid()) @db.Uuid
  organizationId  String           @map("organization_id") @db.Uuid
  email           String
  role            RoleCode
  teamId          String?          @map("team_id") @db.Uuid
  invitedByUserId String           @map("invited_by_user_id") @db.Uuid
  tokenHash       String           @unique @map("token_hash")
  status          InvitationStatus @default(Pending)
  expiresAt       DateTime         @map("expires_at")
  acceptedAt      DateTime?        @map("accepted_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team         Team?        @relation(fields: [teamId], references: [id], onDelete: SetNull)
  invitedBy    User         @relation("InvitedBy", fields: [invitedByUserId], references: [id], onDelete: Restrict)

  @@index([organizationId, email, status])
  @@index([expiresAt])
  @@map("invitations")
}

// ---------------------------------------------------------------------
// Organization / permission tables (DB design §6)
// ---------------------------------------------------------------------

model Organization {
  id              String             @id @default(uuid()) @db.Uuid
  name            String
  slug            String             @unique
  status          OrganizationStatus @default(Active)
  createdByUserId String             @map("created_by_user_id") @db.Uuid
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
  deletedAt       DateTime?          @map("deleted_at")

  createdBy    User                 @relation("OrgCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  teams        Team[]
  memberships  Membership[]
  invitations  Invitation[]
  settings     OrganizationSetting?
  activityLogs ActivityLog[]

  documents             Document[]
  documentVersions      DocumentVersion[]
  documentShares        DocumentShare[]
  documentTags          DocumentTag[]
  documentTagLinks      DocumentTagLink[]
  documentFavorites     DocumentFavorite[]
  documentViewHistories DocumentViewHistory[]

  aiRequests   AiRequest[]
  aiResults    AiResult[]
  aiReferences AiReference[]
  aiUsageLogs  AiUsageLog[]

  @@index([status])
  @@map("organizations")
}

model Team {
  id             String     @id @default(uuid()) @db.Uuid
  organizationId String     @map("organization_id") @db.Uuid
  name           String
  description    String?
  parentTeamId   String?    @map("parent_team_id") @db.Uuid
  managerUserId  String?    @map("manager_user_id") @db.Uuid
  status         TeamStatus @default(Active)
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  deletedAt      DateTime?  @map("deleted_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parentTeam   Team?        @relation("TeamHierarchy", fields: [parentTeamId], references: [id], onDelete: SetNull)
  childTeams   Team[]       @relation("TeamHierarchy")
  manager      User?        @relation("TeamManager", fields: [managerUserId], references: [id], onDelete: SetNull)
  memberships  Membership[]
  invitations  Invitation[]

  ownedDocuments Document[] @relation("DocumentOwnerTeam")

  /// Composite unique on (id, organization_id). Phase C document
  /// tables reference this via composite FK so a document's
  /// owner_team must belong to the same organization as the document.
  @@unique([id, organizationId])
  @@index([organizationId, name])
  @@index([organizationId, status])
  @@map("teams")
}

/// Role definitions. System roles have organization_id=null and is_system=true.
/// Custom org-level roles can be added later (post-MVP).
model Role {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String?  @map("organization_id") @db.Uuid
  code           RoleCode
  name           String
  description    String?
  isSystem       Boolean  @default(false) @map("is_system")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // System roles: code is unique when organizationId is null.
  // Custom roles per org: code is unique within that org.
  // PostgreSQL treats NULLs as distinct, so this tuple constraint does
  // not enforce system-role uniqueness. The separate raw SQL migration
  // `system_role_unique` adds the partial unique index for system roles.
  @@unique([code, organizationId])
  @@map("roles")
}

model Membership {
  id             String           @id @default(uuid()) @db.Uuid
  userId         String           @map("user_id") @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  /// Single primary team (Phase A §15). Multi-team membership is deferred.
  /// May be null for users not yet assigned to any team within the org.
  teamId         String?          @map("team_id") @db.Uuid
  role           RoleCode
  status         MembershipStatus @default(Active)
  joinedAt       DateTime         @default(now()) @map("joined_at")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  deletedAt      DateTime?        @map("deleted_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  team         Team?        @relation(fields: [teamId], references: [id], onDelete: SetNull)

  // (user_id, organization_id) unique: at most one membership row per
  // (user, org). The "single Active membership across all orgs"
  // constraint (Phase A §15: 1 user = 1 organization for MVP) is
  // enforced by a separate partial unique index. See the migration
  // active_membership_unique.
  @@unique([userId, organizationId])
  @@index([organizationId, role])
  @@index([organizationId, teamId])
  @@index([organizationId, status])
  @@map("memberships")
}

// ---------------------------------------------------------------------
// Operations / settings (DB design §12)
// ---------------------------------------------------------------------

model OrganizationSetting {
  organizationId String   @id @map("organization_id") @db.Uuid
  defaultRole    RoleCode @default(Editor) @map("default_role")
  defaultTeamId  String?  @map("default_team_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("organization_settings")
}

model ActivityLog {
  id             String         @id @default(uuid()) @db.Uuid
  organizationId String         @map("organization_id") @db.Uuid
  actorUserId    String?        @map("actor_user_id") @db.Uuid
  action         String
  targetType     String?        @map("target_type")
  targetId       String?        @map("target_id")
  result         ActivityResult
  metadata       Json?
  ipAddress      String?        @map("ip_address")
  userAgent      String?        @map("user_agent")
  createdAt      DateTime       @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor        User?        @relation("ActivityActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([organizationId, actorUserId, createdAt])
  @@index([organizationId, action, createdAt])
  @@map("activity_logs")
}

// ---------------------------------------------------------------------
// Document tables (Phase C / DB design §7)
//
// Scoping rule: every document-related row carries `organization_id`
// even when it is reachable through `document_id`. This denormalisation
// keeps Phase C / F permission filters and audit queries org-scoped
// without an extra join. The application layer is responsible for
// keeping `organization_id` consistent with the parent document.
//
// `templateId` on `Document` remains a nullable Uuid scalar without a
// Prisma `@relation`. The `templates` table lands later in Phase D;
// its FK is added then.
//
// `aiRequestId` was reserved in Phase C as a bare Uuid. Phase D step 1
// adds a single-column FK → `ai_requests(id)` with `onDelete: SetNull`
// so the 90-day AI metadata retention cleanup (DB design §15.3) can
// drop `ai_requests` rows without cascading the deletion to the
// `documents` they generated. Cross-org integrity for `ai_request_id`
// is enforced at the service layer (same pattern as `owner_user_id`).
// A composite FK on `(ai_request_id, organization_id)` was rejected
// because Prisma's `SetNull` cannot null a composite where any column
// is `NOT NULL` (see `owner_team_id` comment in this model).
// ---------------------------------------------------------------------

model Document {
  id             String             @id @default(uuid()) @db.Uuid
  organizationId String             @map("organization_id") @db.Uuid
  title          String
  content        String             @default("") @db.Text
  documentType   String             @map("document_type")
  status         DocumentStatus     @default(Draft)
  ownerUserId    String?            @map("owner_user_id") @db.Uuid
  authorUserId   String?            @map("author_user_id") @db.Uuid
  ownerTeamId    String?            @map("owner_team_id") @db.Uuid
  visibility     DocumentVisibility @default(Private)
  sourceType     DocumentSourceType @default(Manual) @map("source_type")
  /// Forward reference to Phase D `templates`. FK added in Phase D.
  templateId     String?            @map("template_id") @db.Uuid
  /// Forward reference to Phase D `ai_requests`. FK added in Phase D.
  aiRequestId    String?            @map("ai_request_id") @db.Uuid
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  deletedAt      DateTime?          @map("deleted_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner        User?        @relation("DocumentOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  author       User?        @relation("DocumentAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)
  /// Composite FK enforces ownerTeam belongs to the same organization
  /// as the document (Phase C organization-boundary integrity). The
  /// referential action is NoAction because SetNull cannot null the
  /// composite when organization_id is NOT NULL — the application
  /// nulls owner_team_id before any team hard-delete (teams are
  /// normally soft-deleted via deletedAt anyway).
  ownerTeam    Team?        @relation("DocumentOwnerTeam", fields: [ownerTeamId, organizationId], references: [id, organizationId], onDelete: NoAction, onUpdate: NoAction)
  /// Phase D step 1: single-column FK to ai_requests. SetNull lets the
  /// 90-day AI metadata cleanup drop the parent without deleting the
  /// document. Service layer enforces org match.
  aiRequest    AiRequest?   @relation("DocumentAiRequest", fields: [aiRequestId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  versions       DocumentVersion[]
  shares         DocumentShare[]
  tagLinks       DocumentTagLink[]
  favorites      DocumentFavorite[]
  viewHistories  DocumentViewHistory[]
  savedAiResults AiResult[]            @relation("AiResultSavedDocument")

  /// Composite unique on (id, organization_id) so document children
  /// can declare a composite FK on (document_id, organization_id) and
  /// have Postgres reject cross-organization mixes at the DB layer.
  @@unique([id, organizationId])
  @@index([organizationId, status])
  @@index([organizationId, visibility])
  @@index([organizationId, ownerUserId])
  @@index([organizationId, ownerTeamId])
  @@index([organizationId, documentType])
  @@index([organizationId, updatedAt])
  @@map("documents")
}

model DocumentVersion {
  id              String   @id @default(uuid()) @db.Uuid
  documentId      String   @map("document_id") @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  versionNumber   Int      @map("version_number")
  titleSnapshot   String   @map("title_snapshot")
  contentSnapshot String   @map("content_snapshot") @db.Text
  changedByUserId String?  @map("changed_by_user_id") @db.Uuid
  changeSummary   String?  @map("change_summary")
  createdAt       DateTime @default(now()) @map("created_at")

  /// Composite FK on (document_id, organization_id) → documents.
  /// Enforces that a version row's organization matches its parent
  /// document at the DB layer.
  document     Document     @relation(fields: [documentId, organizationId], references: [id, organizationId], onDelete: Cascade, onUpdate: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  changedBy    User?        @relation("DocumentVersionChangedBy", fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@unique([documentId, versionNumber])
  @@index([organizationId, documentId])
  @@map("document_versions")
}

model DocumentShare {
  id              String                  @id @default(uuid()) @db.Uuid
  documentId      String                  @map("document_id") @db.Uuid
  organizationId  String                  @map("organization_id") @db.Uuid
  targetType      DocumentShareTargetType @map("target_type")
  /// User ID, Team ID, or Organization ID depending on `targetType`.
  /// Polymorphic; FK is enforced by application code, not by Prisma.
  targetId        String                  @map("target_id") @db.Uuid
  permission      DocumentSharePermission
  createdByUserId String?                 @map("created_by_user_id") @db.Uuid
  createdAt       DateTime                @default(now()) @map("created_at")
  updatedAt       DateTime                @updatedAt @map("updated_at")

  /// Composite FK on (document_id, organization_id) → documents.
  document     Document     @relation(fields: [documentId, organizationId], references: [id, organizationId], onDelete: Cascade, onUpdate: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation("DocumentShareCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@unique([documentId, targetType, targetId])
  @@index([organizationId, targetType, targetId])
  @@map("document_shares")
}

model DocumentTag {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  name            String
  color           String?
  createdByUserId String?  @map("created_by_user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?             @relation("DocumentTagCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  links        DocumentTagLink[]

  /// Composite unique on (id, organization_id) so document_tag_links
  /// can enforce that a tag and its link share the same organization.
  @@unique([id, organizationId])
  @@unique([organizationId, name])
  @@map("document_tags")
}

model DocumentTagLink {
  id             String   @id @default(uuid()) @db.Uuid
  documentId     String   @map("document_id") @db.Uuid
  tagId          String   @map("tag_id") @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")

  /// Composite FKs on (document_id, organization_id) and
  /// (tag_id, organization_id). Both ensure the link's organization
  /// matches the document's and the tag's at the DB layer.
  document     Document     @relation(fields: [documentId, organizationId], references: [id, organizationId], onDelete: Cascade, onUpdate: Cascade)
  tag          DocumentTag  @relation(fields: [tagId, organizationId], references: [id, organizationId], onDelete: Cascade, onUpdate: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([documentId, tagId])
  @@index([organizationId, tagId])
  @@map("document_tag_links")
}

model DocumentFavorite {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  documentId     String   @map("document_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// Composite FK on (document_id, organization_id) → documents.
  document     Document     @relation(fields: [documentId, organizationId], references: [id, organizationId], onDelete: Cascade, onUpdate: Cascade)

  @@unique([userId, documentId])
  @@index([organizationId, userId])
  @@map("document_favorites")
}

model DocumentViewHistory {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  documentId     String   @map("document_id") @db.Uuid
  viewedAt       DateTime @default(now()) @map("viewed_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// Composite FK on (document_id, organization_id) → documents.
  document     Document     @relation(fields: [documentId, organizationId], references: [id, organizationId], onDelete: Cascade, onUpdate: Cascade)

  @@index([organizationId, userId, viewedAt])
  @@index([documentId])
  @@map("document_view_histories")
}

// ---------------------------------------------------------------------
// AI metadata tables (DB design §9). Phase D step 1.
//
// Body-retention policy (Phase A §15 / docs/ai/notive-ai-generation-
// policy-v1.0.md §12):
//   - ai_requests and ai_results store metadata only. Prompt body and
//     response body are NEVER stored in these tables. There is no
//     `request_text`, `prompt`, `content`, or `response` column.
//   - Preview / edit-stage body lives in session-bound short-term
//     storage (Redis etc.); persistence happens only via the `documents`
//     table when the user explicitly saves.
//   - opt-in "report" flow stores a single request's body in
//     `ai_request_payloads` for 30 days — that table is added in a
//     later Phase D step, not here.
//
// Organization integrity:
//   - ai_requests has a composite UNIQUE (id, organization_id) so
//     ai_results / ai_references can declare composite FKs to it and
//     have Postgres reject cross-org mixes at the DB layer (same
//     pattern as documents in Phase C).
//
// Retention: ai_requests / ai_results / ai_references / ai_usage_logs
// metadata is kept 90 days (DB design §15.3). A future background job
// will delete by retain-window; documents linked via
// `documents.ai_request_id` survive because that FK is SetNull.
// ---------------------------------------------------------------------

model AiRequest {
  id                String          @id @default(uuid()) @db.Uuid
  organizationId    String          @map("organization_id") @db.Uuid
  requestedByUserId String?         @map("requested_by_user_id") @db.Uuid
  documentType      String          @map("document_type")
  /// Forward reference to Phase D `templates`. FK added when that table lands.
  templateId        String?         @map("template_id") @db.Uuid
  /// Structured generation tag. Free-text prompt body is NOT stored.
  purpose           String?
  /// Structured generation tag. Free-text prompt body is NOT stored.
  audience          String?
  /// Structured generation tag. Free-text prompt body is NOT stored.
  tone              String?
  status            AiRequestStatus @default(Pending)
  errorCode         String?         @map("error_code")
  latencyMs         Int?            @map("latency_ms")
  tokenCountInput   Int?            @map("token_count_input")
  tokenCountOutput  Int?            @map("token_count_output")
  resultSaved       Boolean         @default(false) @map("result_saved")
  startedAt         DateTime?       @map("started_at")
  completedAt       DateTime?       @map("completed_at")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  requestedBy  User?        @relation("AiRequestRequestedBy", fields: [requestedByUserId], references: [id], onDelete: SetNull)

  results    AiResult[]
  references AiReference[]
  usageLogs  AiUsageLog[]
  documents  Document[]    @relation("DocumentAiRequest")

  /// Composite unique on (id, organization_id) so ai_results /
  /// ai_references can declare composite FKs and have Postgres
  /// enforce same-organization parent/child at the DB layer.
  @@unique([id, organizationId])
  @@index([organizationId, requestedByUserId, createdAt])
  @@index([organizationId, status])
  @@map("ai_requests")
}

model AiResult {
  id              String         @id @default(uuid()) @db.Uuid
  aiRequestId     String         @map("ai_request_id") @db.Uuid
  organizationId  String         @map("organization_id") @db.Uuid
  status          AiResultStatus @default(Generated)
  /// Inverse pointer set only when the user explicitly saves the
  /// result as a `documents` row. Composite FK on
  /// (saved_document_id, organization_id) so Postgres rejects an
  /// ai_result that points at a foreign-org document. Hard-delete of a
  /// document is not the normal path (Phase C uses soft-delete via
  /// status=Deleted + deletedAt); NoAction blocks an accidental hard
  /// delete that would orphan this pointer, and the application is
  /// expected to null `saved_document_id` before any operational hard
  /// delete (same operational contract as documents.owner_team_id).
  savedDocumentId String?        @map("saved_document_id") @db.Uuid
  errorCode       String?        @map("error_code")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  /// Composite FK on (ai_request_id, organization_id) → ai_requests.
  /// Enforces same-organization at the DB layer.
  aiRequest     AiRequest    @relation(fields: [aiRequestId, organizationId], references: [id, organizationId], onDelete: Cascade, onUpdate: Cascade)
  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  savedDocument Document?    @relation("AiResultSavedDocument", fields: [savedDocumentId, organizationId], references: [id, organizationId], onDelete: NoAction, onUpdate: NoAction)

  @@index([aiRequestId])
  @@index([organizationId, status])
  @@map("ai_results")
}

model AiReference {
  id             String                @id @default(uuid()) @db.Uuid
  aiRequestId    String                @map("ai_request_id") @db.Uuid
  organizationId String                @map("organization_id") @db.Uuid
  targetType     AiReferenceTargetType @map("target_type")
  targetId       String                @map("target_id") @db.Uuid
  /// Snapshot of the target's title at request time. Used so the audit
  /// trail survives even if the target is later renamed or deleted.
  targetTitle    String?               @map("target_title")
  /// Snapshot of whether the requesting user had View on the target at
  /// the time of generation. The service layer is responsible for
  /// filtering out unviewable references BEFORE recording — this column
  /// is the audit record, not the gate.
  accessAllowed  Boolean               @map("access_allowed")
  createdAt      DateTime              @default(now()) @map("created_at")

  /// Composite FK on (ai_request_id, organization_id) → ai_requests.
  aiRequest    AiRequest    @relation(fields: [aiRequestId, organizationId], references: [id, organizationId], onDelete: Cascade, onUpdate: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([aiRequestId, targetType, targetId])
  @@index([organizationId, targetType])
  @@map("ai_references")
}

model AiUsageLog {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  userId         String?       @map("user_id") @db.Uuid
  /// Sibling reference (not parent-child). SetNull so usage history
  /// survives 90-day metadata cleanup of ai_requests for billing /
  /// quality analysis (DB design §15.2 retention).
  aiRequestId    String?       @map("ai_request_id") @db.Uuid
  documentType   String        @map("document_type")
  status         AiUsageStatus
  durationMs     Int?          @map("duration_ms")
  createdAt      DateTime      @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  aiRequest    AiRequest?   @relation(fields: [aiRequestId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([organizationId, userId])
  @@map("ai_usage_logs")
}
